{
	"name": "n8n-nodes-linktwin",
	"version": "1.0.4",
	"description": "n8n community node for LinkTwin - Deep Linking & URL Shortener — Turn any link into a smart deep link that opens directly in the right app (YouTube, Amazon, Spotify & 100+ apps) or in the user's external browser, boosting clicks and conversions",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"deep-links",
		"deep-linking",
		"app-deep-linking",
		"app-opener",
		"link-management",
		"analytics",
		"linktwin"
	],
	"license": "MIT",
	"homepage": "https://linktw.in",
	"author": {
		"name": "LinkTwin",
		"email": "support@linktw.in"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/LinkTwin/n8n-nodes-linktwin"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes/**/*.ts credentials/**/*.ts",
		"lintfix": "eslint nodes/**/*.ts credentials/**/*.ts --fix",
		"prepublishOnly": "npm run build && npm run lint"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/LinkTwinApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/LinkTwin/LinkTwin.node.js"
		]
	},
	"devDependencies": {
		"@types/node": "^20.10.0",
		"@typescript-eslint/parser": "^7.0.0",
		"eslint": "^8.56.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.0",
		"gulp": "^4.0.2",
		"n8n-workflow": "*",
		"prettier": "^3.2.0",
		"typescript": "^5.3.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
